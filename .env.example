# Local app environment for Oval.
# This file is for local development only and should be copied to `.env`.
# The values below are injected into Flutter via ./scripts/flutter_with_env.sh
# and are also read by native Android/iOS build scripts for Google Maps setup.

APP_ENV=development
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
